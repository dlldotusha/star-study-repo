@page "/admin"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject AdminApiClient Api

<PageTitle>Панель управления</PageTitle>

<div class="admin-shell">
    @if (!isLoggedIn)
    {
        <div class="card shadow-sm admin-login-card">
            <div class="card-header bg-primary text-white">
                <h1 class="h5 mb-0">Star-Study · вход тестирующего</h1>
            </div>
            <div class="card-body">
                <form @onsubmit="LoginAsync" @onsubmit:preventDefault>
                    <div class="mb-3">
                        <label class="form-label">Логин</label>
                        <input class="form-control" autocomplete="username" @bind="login.Login" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Пароль</label>
                        <input class="form-control" type="password" autocomplete="current-password" @bind="login.Password" />
                    </div>
                    @if (!string.IsNullOrWhiteSpace(message))
                    {
                        <div class="alert alert-info">@message</div>
                    }
                    <button class="btn btn-primary" type="submit" disabled="@isBusy">Войти</button>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
            <div>
                <p class="text-uppercase text-primary fw-bold small mb-1">Star-Study Admin</p>
                <h1 class="display-6 mb-1">Панель управления тестами</h1>
                <p class="text-secondary mb-0">Создать тест, добавить вопросы и учеников, опубликовать, проверить ответы.</p>
            </div>
            <button class="btn btn-outline-secondary" @onclick="LogoutAsync">Выйти</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="alert alert-info">@message</div>
        }

        <ul class="nav nav-tabs mb-4">
            <li class="nav-item"><button class="@TabClass("tests")" @onclick='() => SetTabAsync("tests")'>Тесты</button></li>
            <li class="nav-item"><button class="@TabClass("edit")" @onclick='() => SetTabAsync("edit")'>Редактор</button></li>
            <li class="nav-item"><button class="@TabClass("groups")" @onclick='() => SetTabAsync("groups")'>Группы</button></li>
            <li class="nav-item"><button class="@TabClass("attempts")" @onclick='() => SetTabAsync("attempts")'>Прохождения</button></li>
            <li class="nav-item"><button class="@TabClass("export")" @onclick='() => SetTabAsync("export")'>CSV</button></li>
        </ul>

        @if (activeTab == "tests")
        {
            <div class="card shadow-sm">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h2 class="h5 mb-0">Мои тесты</h2>
                    <button class="btn btn-primary btn-sm" @onclick="CreateTestAsync" disabled="@isBusy">Создать тест</button>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Название</th>
                                <th>Статус</th>
                                <th>Вопросы</th>
                                <th>Ученики</th>
                                <th>Начали</th>
                                <th>Закончили</th>
                                <th>Создан</th>
                                <th>Изменён</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var test in tests)
                            {
                                <tr>
                                    <td class="fw-semibold">@test.Title</td>
                                    <td><span class="@StatusBadge(test.Status)">@StatusText(test.Status)</span></td>
                                    <td>@test.QuestionCount</td>
                                    <td>@test.AssignedStudentCount</td>
                                    <td>@test.StartedCount</td>
                                    <td>@test.FinishedCount</td>
                                    <td>@test.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@test.UpdatedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td><button class="btn btn-outline-primary btn-sm" @onclick="() => OpenTestAsync(test.Id)">Открыть</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (activeTab == "groups")
        {
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="card shadow-sm">
                        <div class="card-header">
                            <h2 class="h5 mb-0">Группы учеников</h2>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Название группы</label>
                                <input class="form-control" placeholder="Например: 9А" @bind="groupDraft.Name" />
                            </div>
                            <button class="btn btn-primary" @onclick="SaveGroupAsync" disabled="@isBusy">Сохранить группу</button>
                        </div>
                        <div class="list-group list-group-flush">
                            @foreach (var group in groups)
                            {
                                <button class="@GroupListClass(group.Id)" @onclick="() => SelectGroup(group)">
                                    <span class="fw-semibold">@group.Name</span>
                                    <span class="badge text-bg-secondary">@group.Students.Count</span>
                                </button>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-lg-8">
                    @if (currentGroup is null)
                    {
                        <div class="alert alert-info">Создайте группу или выберите существующую, чтобы добавить учеников.</div>
                    }
                    else
                    {
                        <div class="card shadow-sm">
                            <div class="card-header d-flex align-items-center justify-content-between">
                                <h2 class="h5 mb-0">@currentGroup.Name</h2>
                                <span class="text-secondary">@currentGroup.Students.Count учеников</span>
                            </div>
                            <div class="card-body">
                                <div class="row g-2">
                                    <div class="col-sm-5"><input class="form-control" placeholder="логин ученика" @bind="groupStudentDraft.Login" /></div>
                                    <div class="col-sm-5"><input class="form-control" placeholder="пароль" @bind="groupStudentDraft.Password" /></div>
                                    <div class="col-sm-2"><button class="btn btn-success w-100" @onclick="SaveGroupStudentAsync" disabled="@isBusy">Добавить</button></div>
                                </div>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-sm table-striped align-middle mb-0">
                                    <thead class="table-light"><tr><th>Логин</th><th>Пароль</th></tr></thead>
                                    <tbody>
                                        @foreach (var student in currentGroup.Students)
                                        {
                                            <tr>
                                                <td>@student.Login</td>
                                                <td><code>@student.Password</code></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (activeTab == "edit")
        {
            @if (currentTest is null)
            {
                <div class="alert alert-warning">Выберите тест из списка или создайте новый.</div>
            }
            else
            {
                <div class="row g-4">
                    <div class="col-lg-5">
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-primary text-white">
                                <h2 class="h5 mb-0">Настройки теста</h2>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label">Название</label>
                                    <input class="form-control" @bind="currentTest.Title" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Описание Markdown</label>
                                    <textarea class="form-control" rows="7" @bind="currentTest.Description"></textarea>
                                </div>
                                <div class="row g-3">
                                    <div class="col-sm-6">
                                        <label class="form-label">Время, минут</label>
                                        <InputNumber class="form-control" @bind-Value="currentTest.TimeLimitMinutes" />
                                    </div>
                                    <div class="col-sm-6">
                                        <label class="form-label">Попыток</label>
                                        <InputNumber class="form-control" @bind-Value="currentTest.AttemptLimit" />
                                    </div>
                                </div>

                                <div class="mt-3">
                                    <div class="form-check"><input class="form-check-input" type="checkbox" @bind="currentTest.AllowResume" /><label class="form-check-label">Разрешить продолжение после перезагрузки</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" @bind="currentTest.AllowBackNavigation" /><label class="form-check-label">Разрешить возврат к вопросам</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" @bind="currentTest.ShuffleQuestions" /><label class="form-check-label">Перемешивать вопросы</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" @bind="currentTest.ShuffleOptions" /><label class="form-check-label">Перемешивать варианты</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" @bind="currentTest.ShowResultToStudent" /><label class="form-check-label">Показывать результат ученику</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" @bind="currentTest.ShowCorrectAnswers" /><label class="form-check-label">Показывать правильные ответы</label></div>
                                </div>

                                <button class="btn btn-success mt-3" @onclick="SaveTestAsync" disabled="@isBusy">Сохранить настройки</button>
                            </div>
                        </div>

                        <div class="card shadow-sm">
                            <div class="card-header">
                                <h2 class="h5 mb-0">Публикация</h2>
                            </div>
                            <div class="card-body">
                                <p>Статус: <span class="@StatusBadge(currentTest.Status)">@StatusText(currentTest.Status)</span></p>
                                @if (currentTest.ValidationMessages.Count > 0)
                                {
                                    <div class="alert alert-warning">
                                        @foreach (var validation in currentTest.ValidationMessages)
                                        {
                                            <div>@validation</div>
                                        }
                                    </div>
                                }
                                <div class="d-flex gap-2">
                                    <button class="btn btn-primary" @onclick="PublishAsync" disabled="@isBusy">Опубликовать</button>
                                    <button class="btn btn-warning" @onclick="CloseAsync" disabled="@isBusy">Закрыть</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-7">
                        <div class="card shadow-sm mb-4">
                            <div class="card-header">
                                <h2 class="h5 mb-0">Вопросы</h2>
                            </div>
                            <div class="card-body">
                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    <select class="form-select admin-type-select" @bind="questionDraft.Type">
                                        <option value="text">Ввод строки</option>
                                        <option value="single">Один вариант</option>
                                        <option value="multi">Несколько вариантов</option>
                                        <option value="markdown">Markdown-блок</option>
                                        <option value="match">Соединение терминов</option>
                                        <option value="blanks">Пропуски</option>
                                        <option value="table">Таблица</option>
                                    </select>
                                    <InputNumber class="form-control admin-points-input" @bind-Value="questionDraft.Points" />
                                    <button class="btn btn-outline-secondary" @onclick="NewQuestionDraft">Новый вопрос</button>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Текст вопроса Markdown</label>
                                    <textarea class="form-control" rows="4" @bind="questionDraft.Text"></textarea>
                                </div>

                                @if (questionDraft.Type == "text")
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Правильный ответ</label>
                                        <input class="form-control" @bind="questionDraft.CorrectText" />
                                    </div>
                                }

                                @if (questionDraft.Type == "single" || questionDraft.Type == "multi")
                                {
                                    <label class="form-label">Варианты ответа</label>
                                    @foreach (var option in questionDraft.Options)
                                    {
                                        <div class="input-group mb-2">
                                            <span class="input-group-text">
                                                <input class="form-check-input mt-0" type="checkbox" checked="@questionDraft.CorrectOptionIds.Contains(option.Id)" @onchange="args => ToggleCorrectOption(option.Id, args)" />
                                            </span>
                                            <input class="form-control" @bind="option.Text" />
                                        </div>
                                    }
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="AddOption">Добавить вариант</button>
                                }

                                <div class="mb-3 mt-3">
                                    <label class="form-label">Комментарий для проверяющего</label>
                                    <input class="form-control" @bind="questionDraft.ReviewerComment" />
                                </div>
                                <button class="btn btn-success" @onclick="SaveQuestionAsync" disabled="@isBusy">Сохранить вопрос</button>

                                <hr />
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle">
                                        <thead class="table-light">
                                            <tr><th>ID</th><th>Тип</th><th>Текст</th><th>Баллы</th><th></th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var question in currentTest.Questions)
                                            {
                                                <tr>
                                                    <td><code>@question.Id</code></td>
                                                    <td>@question.Type</td>
                                                    <td>@Short(question.Text)</td>
                                                    <td>@question.Points</td>
                                                    <td><button class="btn btn-outline-primary btn-sm" @onclick="() => EditQuestion(question)">Править</button></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="card shadow-sm">
                            <div class="card-header">
                                <h2 class="h5 mb-0">Ученики и доступ</h2>
                            </div>
                            <div class="card-body">
                                <div class="row g-2">
                                    <div class="col-sm-4"><input class="form-control" placeholder="логин" @bind="studentDraft.Login" /></div>
                                    <div class="col-sm-4"><input class="form-control" placeholder="пароль" @bind="studentDraft.Password" /></div>
                                    <div class="col-sm-2"><InputNumber class="form-control" @bind-Value="studentDraft.AttemptLimit" /></div>
                                    <div class="col-sm-2"><button class="btn btn-success w-100" @onclick="SaveStudentAsync" disabled="@isBusy">Добавить</button></div>
                                </div>
                                <div class="table-responsive mt-3">
                                    <table class="table table-sm">
                                        <thead class="table-light"><tr><th>Логин</th><th>Попыток</th><th>Продолжение</th><th>Назад</th></tr></thead>
                                        <tbody>
                                            @foreach (var student in currentTest.Students)
                                            {
                                                <tr>
                                                    <td>@student.Login</td>
                                                    <td>@student.AttemptLimit</td>
                                                    <td>@YesNo(student.AllowResume)</td>
                                                    <td>@YesNo(student.AllowBackNavigation)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>

                                <hr />
                                <h3 class="h6">Доступ по группе</h3>
                                @if (groups.Count == 0)
                                {
                                    <div class="alert alert-info py-2">Сначала создайте группу на вкладке “Группы”.</div>
                                }
                                else
                                {
                                    <div class="row g-2 align-items-end">
                                        <div class="col-sm-5">
                                            <label class="form-label">Группа</label>
                                            <select class="form-select" @bind="groupAccessDraft.GroupId">
                                                <option value="">Выберите группу</option>
                                                @foreach (var group in groups)
                                                {
                                                    <option value="@group.Id">@group.Name (@group.Students.Count)</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-sm-3">
                                            <label class="form-label">Попыток</label>
                                            <InputNumber class="form-control" @bind-Value="groupAccessDraft.AttemptLimit" />
                                        </div>
                                        <div class="col-sm-4">
                                            <button class="btn btn-outline-success w-100" @onclick="AssignGroupAsync" disabled="@isBusy">Назначить группу</button>
                                        </div>
                                    </div>
                                }

                                <div class="table-responsive mt-3">
                                    <table class="table table-sm">
                                        <thead class="table-light"><tr><th>Группа</th><th>Ученики</th><th>Попыток</th><th>Продолжение</th><th>Назад</th></tr></thead>
                                        <tbody>
                                            @foreach (var group in currentTest.Groups)
                                            {
                                                <tr>
                                                    <td>@group.GroupName</td>
                                                    <td>@group.StudentCount</td>
                                                    <td>@group.AttemptLimit</td>
                                                    <td>@YesNo(group.AllowResume)</td>
                                                    <td>@YesNo(group.AllowBackNavigation)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }

        @if (activeTab == "attempts")
        {
            <div class="card shadow-sm">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h2 class="h5 mb-0">Мониторинг прохождений</h2>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="LoadAttemptsAsync">Обновить</button>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Ученик</th>
                                <th>Тест</th>
                                <th>Статус</th>
                                <th>Вопрос</th>
                                <th>Открыл</th>
                                <th>Ответил</th>
                                <th>Последний запрос</th>
                                <th>Итог</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var attempt in attempts)
                            {
                                <tr>
                                    <td>@attempt.StudentLogin</td>
                                    <td>@attempt.TestTitle</td>
                                    <td>@attempt.Status</td>
                                    <td>@attempt.CurrentQuestionNumber</td>
                                    <td>@attempt.OpenedQuestionCount</td>
                                    <td>@attempt.SubmittedAnswerCount</td>
                                    <td>@attempt.LastRequestAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm:ss")</td>
                                    <td>@attempt.TotalPoints / @attempt.MaxPoints (@attempt.Percent%)</td>
                                    <td><button class="btn btn-outline-primary btn-sm" @onclick="() => OpenAttemptAsync(attempt.AttemptId)">Ответы</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (currentAttempt is not null)
            {
                <div class="row g-4 mt-1">
                    <div class="col-lg-4">
                        <div class="card border-info shadow-sm">
                            <div class="card-header bg-info-subtle">
                                <h2 class="h5 mb-0">Timeline</h2>
                            </div>
                            <ul class="list-group list-group-flush">
                                @foreach (var line in currentAttempt.Timeline)
                                {
                                    <li class="list-group-item">@line</li>
                                }
                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-8">
                        <div class="card shadow-sm">
                            <div class="card-header">
                                <h2 class="h5 mb-0">Ответы ученика</h2>
                            </div>
                            <div class="card-body">
                                @foreach (var answer in currentAttempt.Answers)
                                {
                                    <div class="border rounded-3 bg-light p-3 mb-3">
                                        <h3 class="h6">Вопрос @answer.Number · @answer.ReviewStatus</h3>
                                        <p><strong>Текст:</strong> @answer.QuestionText</p>
                                        <p><strong>Ответ ученика:</strong> @answer.StudentAnswer</p>
                                        <p><strong>Правильный ответ:</strong> @answer.CorrectAnswer</p>
                                        <p><strong>Открыт:</strong> @FormatDate(answer.OpenedAt) · <strong>Отправлен:</strong> @FormatDate(answer.SubmittedAt)</p>
                                        <div class="d-flex flex-wrap align-items-center gap-2">
                                            <InputNumber class="form-control admin-points-input" @bind-Value="answer.Points" />
                                            <span>из @answer.MaxPoints</span>
                                            <input class="form-control admin-comment-input" placeholder="комментарий" @bind="answer.ReviewerComment" />
                                            <button class="btn btn-success btn-sm" @onclick="() => GradeAsync(answer)">Сохранить оценку</button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }

        @if (activeTab == "export")
        {
            <div class="card shadow-sm">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h2 class="h5 mb-0">Экспорт результатов CSV</h2>
                    <button class="btn btn-primary btn-sm" @onclick="ExportCsvAsync">Сформировать CSV</button>
                </div>
                <div class="card-body">
                    @if (csvExport is not null)
                    {
                        <p><strong>@csvExport.FileName</strong></p>
                        <textarea class="form-control font-monospace" rows="16" readonly>@csvExport.Content</textarea>
                    }
                    else
                    {
                        <p class="text-secondary">CSV появится здесь после формирования.</p>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private readonly AdminLoginData login = new();
    private IReadOnlyList<AdminTestSummary> tests = [];
    private IReadOnlyList<AdminAttemptSummary> attempts = [];
    private IReadOnlyList<AdminGroupEdit> groups = [];
    private AdminTestEdit? currentTest;
    private AdminAttemptDetails? currentAttempt;
    private AdminGroupEdit? currentGroup;
    private AdminQuestionEdit questionDraft = NewQuestion();
    private AdminStudentAccessEdit studentDraft = new() { AttemptLimit = 1, AllowResume = true, AllowBackNavigation = true };
    private AdminSaveGroupData groupDraft = new();
    private AdminGroupStudentEdit groupStudentDraft = new();
    private AdminGroupAccessEdit groupAccessDraft = new() { AttemptLimit = 1, AllowResume = true, AllowBackNavigation = true };
    private AdminCsvExport? csvExport;
    private bool isLoggedIn;
    private bool isBusy;
    private string activeTab = "tests";
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        isLoggedIn = !string.IsNullOrWhiteSpace(await Api.GetTokenAsync());

        if (isLoggedIn)
        {
            await LoadTestsAsync();
            await LoadGroupsAsync();
        }
    }

    private async Task LoginAsync()
    {
        await RunAsync(async () =>
        {
            var result = await Api.LoginAsync(login);
            message = result.Message;
            isLoggedIn = result.Success;

            if (isLoggedIn)
            {
                await LoadTestsAsync();
                await LoadGroupsAsync();
            }
        });
    }

    private async Task LogoutAsync()
    {
        await Api.LogoutAsync();
        isLoggedIn = false;
        currentTest = null;
        currentAttempt = null;
        message = null;
    }

    private async Task LoadTestsAsync()
    {
        tests = await Api.GetTestsAsync();
    }

    private async Task LoadGroupsAsync()
    {
        groups = await Api.GetGroupsAsync();

        if (currentGroup is not null)
        {
            currentGroup = groups.FirstOrDefault(group => group.Id == currentGroup.Id);
        }

        if (string.IsNullOrWhiteSpace(groupAccessDraft.GroupId) && groups.Count > 0)
        {
            groupAccessDraft.GroupId = groups[0].Id;
        }
    }

    private async Task LoadAttemptsAsync()
    {
        attempts = await Api.GetAttemptsAsync();
    }

    private async Task CreateTestAsync()
    {
        await RunAsync(async () =>
        {
            currentTest = await Api.CreateTestAsync(new AdminCreateTestData
            {
                Title = "Новый тест",
                Description = "# Новый тест"
            });
            activeTab = "edit";
            await LoadTestsAsync();
        });
    }

    private async Task OpenTestAsync(string testId)
    {
        await RunAsync(async () =>
        {
            currentTest = await Api.GetTestAsync(testId);
            questionDraft = NewQuestion();
            await LoadGroupsAsync();
            activeTab = "edit";
        });
    }

    private async Task SaveTestAsync()
    {
        if (currentTest is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            currentTest = await Api.SaveTestAsync(new AdminSaveTestData
            {
                TestId = currentTest.Id,
                Title = currentTest.Title,
                Description = currentTest.Description,
                TimeLimitMinutes = currentTest.TimeLimitMinutes,
                AttemptLimit = currentTest.AttemptLimit,
                AllowResume = currentTest.AllowResume,
                AllowBackNavigation = currentTest.AllowBackNavigation,
                ShuffleQuestions = currentTest.ShuffleQuestions,
                ShuffleOptions = currentTest.ShuffleOptions,
                ShowResultToStudent = currentTest.ShowResultToStudent,
                ShowCorrectAnswers = currentTest.ShowCorrectAnswers
            });
            message = "Настройки сохранены.";
            await LoadTestsAsync();
        });
    }

    private async Task SaveQuestionAsync()
    {
        if (currentTest is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            currentTest = await Api.SaveQuestionAsync(new AdminSaveQuestionData
            {
                TestId = currentTest.Id,
                Question = questionDraft
            });
            questionDraft = NewQuestion();
            await LoadTestsAsync();
        });
    }

    private async Task SaveStudentAsync()
    {
        if (currentTest is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            currentTest = await Api.SaveStudentAsync(new AdminSaveStudentData
            {
                TestId = currentTest.Id,
                Student = studentDraft
            });
            studentDraft = new AdminStudentAccessEdit { AttemptLimit = 1, AllowResume = true, AllowBackNavigation = true };
            await LoadTestsAsync();
        });
    }

    private async Task SaveGroupAsync()
    {
        await RunAsync(async () =>
        {
            currentGroup = await Api.SaveGroupAsync(groupDraft);
            groupDraft = new AdminSaveGroupData();
            await LoadGroupsAsync();
            await RefreshCurrentTestAsync();
        });
    }

    private void SelectGroup(AdminGroupEdit group)
    {
        currentGroup = group;
        groupDraft = new AdminSaveGroupData { GroupId = group.Id, Name = group.Name };
        groupStudentDraft = new AdminGroupStudentEdit();
    }

    private async Task SaveGroupStudentAsync()
    {
        if (currentGroup is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            currentGroup = await Api.SaveGroupStudentAsync(new AdminSaveGroupStudentData
            {
                GroupId = currentGroup.Id,
                Student = groupStudentDraft
            });
            groupStudentDraft = new AdminGroupStudentEdit();
            await LoadGroupsAsync();
            await LoadTestsAsync();
            await RefreshCurrentTestAsync();
        });
    }

    private async Task AssignGroupAsync()
    {
        if (currentTest is null || string.IsNullOrWhiteSpace(groupAccessDraft.GroupId))
        {
            return;
        }

        await RunAsync(async () =>
        {
            currentTest = await Api.AssignGroupAsync(new AdminAssignGroupData
            {
                TestId = currentTest.Id,
                Group = groupAccessDraft
            });
            groupAccessDraft = new AdminGroupAccessEdit { AttemptLimit = 1, AllowResume = true, AllowBackNavigation = true };
            await LoadGroupsAsync();
            await LoadTestsAsync();
        });
    }

    private async Task RefreshCurrentTestAsync()
    {
        if (currentTest is not null)
        {
            currentTest = await Api.GetTestAsync(currentTest.Id);
        }
    }

    private async Task PublishAsync()
    {
        if (currentTest is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            var result = await Api.PublishAsync(currentTest.Id);
            message = result.Message;
            currentTest = await Api.GetTestAsync(currentTest.Id);
            await LoadTestsAsync();
        });
    }

    private async Task CloseAsync()
    {
        if (currentTest is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            currentTest = await Api.CloseAsync(currentTest.Id);
            await LoadTestsAsync();
        });
    }

    private async Task OpenAttemptAsync(string attemptId)
    {
        await RunAsync(async () =>
        {
            currentAttempt = await Api.GetAttemptAsync(attemptId);
        });
    }

    private async Task GradeAsync(AdminAnswerReview answer)
    {
        if (currentAttempt is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            currentAttempt = await Api.GradeAsync(new AdminGradeData
            {
                AttemptId = currentAttempt.Summary.AttemptId,
                QuestionId = answer.QuestionId,
                Points = answer.Points,
                ReviewerComment = answer.ReviewerComment
            });
            await LoadAttemptsAsync();
        });
    }

    private async Task ExportCsvAsync()
    {
        await RunAsync(async () =>
        {
            csvExport = await Api.ExportCsvAsync();
        });
    }

    private async Task SetTabAsync(string tab)
    {
        activeTab = tab;

        if (tab == "attempts")
        {
            await LoadAttemptsAsync();
        }

        if (tab == "groups")
        {
            await LoadGroupsAsync();
        }
    }

    private void NewQuestionDraft()
    {
        questionDraft = NewQuestion();
    }

    private void EditQuestion(AdminQuestionEdit question)
    {
        questionDraft = new AdminQuestionEdit
        {
            Id = question.Id,
            Type = question.Type,
            Text = question.Text,
            CorrectText = question.CorrectText,
            Points = question.Points,
            ReviewerComment = question.ReviewerComment,
            Options = question.Options.Select(option => new AdminOptionEdit { Id = option.Id, Text = option.Text }).ToList(),
            CorrectOptionIds = question.CorrectOptionIds.ToList()
        };
    }

    private void AddOption()
    {
        questionDraft.Options.Add(new AdminOptionEdit { Id = Guid.NewGuid().ToString("N")[..8], Text = "Новый вариант" });
    }

    private void ToggleCorrectOption(string optionId, ChangeEventArgs args)
    {
        if (questionDraft.Type == "single")
        {
            questionDraft.CorrectOptionIds.Clear();
        }

        if (args.Value is true)
        {
            questionDraft.CorrectOptionIds.Add(optionId);
        }
        else
        {
            questionDraft.CorrectOptionIds.Remove(optionId);
        }
    }

    private async Task RunAsync(Func<Task> action)
    {
        try
        {
            isBusy = true;
            message = null;
            await action();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private static AdminQuestionEdit NewQuestion()
    {
        return new AdminQuestionEdit
        {
            Id = Guid.NewGuid().ToString("N")[..8],
            Type = "text",
            Points = 1,
            Options =
            [
                new AdminOptionEdit { Id = Guid.NewGuid().ToString("N")[..8], Text = "Вариант 1" },
                new AdminOptionEdit { Id = Guid.NewGuid().ToString("N")[..8], Text = "Вариант 2" }
            ]
        };
    }

    private string TabClass(string tab)
    {
        return activeTab == tab ? "nav-link active" : "nav-link";
    }

    private string GroupListClass(string groupId)
    {
        return currentGroup?.Id == groupId
            ? "list-group-item list-group-item-action active d-flex justify-content-between align-items-center"
            : "list-group-item list-group-item-action d-flex justify-content-between align-items-center";
    }

    private static string Short(string value)
    {
        return value.Length <= 70 ? value : $"{value[..70]}...";
    }

    private static string YesNo(bool value)
    {
        return value ? "да" : "нет";
    }

    private static string FormatDate(DateTimeOffset? value)
    {
        return value?.LocalDateTime.ToString("dd.MM.yyyy HH:mm:ss") ?? "-";
    }

    private static string StatusText(string status)
    {
        return status switch
        {
            AdminTestStatuses.Draft => "черновик",
            AdminTestStatuses.Published => "опубликован",
            AdminTestStatuses.Closed => "закрыт",
            _ => status
        };
    }

    private static string StatusBadge(string status)
    {
        return status switch
        {
            AdminTestStatuses.Published => "badge text-bg-success",
            AdminTestStatuses.Closed => "badge text-bg-secondary",
            _ => "badge text-bg-warning"
        };
    }
}
